{
  "cleanUrls": true,
  "buildCommand": "node scripts/build-case-studies.mjs && node scripts/build-blog.mjs && node scripts/build-es.mjs",
  "outputDirectory": ".",
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/index", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true }
  ],
  "crons": [
    { "path": "/api/airbnb-sync", "schedule": "0 13 * * *" }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:webp|jpg|jpeg|png|svg|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/styles/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/iptv-47f468d0-141e-40dd-a421-3a7e1176b6aa/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" },
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/iptv-47f468d0-141e-40dd-a421-3a7e1176b6aa/playlist.m3u",
      "headers": [
        { "key": "Content-Type", "value": "application/x-mpegURL; charset=utf-8" }
      ]
    },
    {
      "source": "/iptv-47f468d0-141e-40dd-a421-3a7e1176b6aa/epg.xml.gz",
      "headers": [
        { "key": "Content-Type", "value": "application/gzip" },
        { "key": "Content-Encoding", "value": "identity" }
      ]
    },
    {
      "source": "/iptv-47f468d0-141e-40dd-a421-3a7e1176b6aa/epg-gz.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Content-Encoding", "value": "gzip" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    }
  ]
}
